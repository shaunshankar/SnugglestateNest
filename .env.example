# Neon Auth — get from your Neon project dashboard under Auth
VITE_NEON_AUTH_URL=https://your-project-ref.auth.neon.tech

# Neon Data API — get from your Neon project dashboard under Data API
VITE_NEON_DATA_API_URL=https://your-project-ref.db.neon.tech

# Neon Postgres connection string — used by the Vercel serverless function
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Resend — get from https://resend.com/api-keys
# Used only in the Vercel serverless function (api/bill-reminders.js), not exposed to the browser
RESEND_API_KEY=re_...

# Anthropic — get from https://console.anthropic.com/
# WARNING: This key is exposed in the browser bundle. For production,
# proxy calls through a Vercel serverless function instead.
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Your deployed app URL (for links in bill reminder emails)
VITE_APP_URL=https://your-app.vercel.app
